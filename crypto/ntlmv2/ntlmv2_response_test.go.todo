package ntlmv2

import "testing"

func TestNTLMv2Response(t *testing.T) {
	testCases := []struct {
		name                string
		username            string
		domain              string
		serverChallenge     [8]byte
		lmChallengeResponse [24]byte
		ntChallengeResponse [24]byte
		expectedHashcat     string
	}{
		{
			name:     "Basic NTLMv2 Response",
			username: "username",
			domain:   "domain",
			serverChallenge: [8]byte{
				0x11, 0x22, 0x33, 0x44, 0x55, 0x66, 0x77, 0x88,
			},
			lmChallengeResponse: [24]byte{
				0x11, 0x22, 0x33, 0x44, 0x55, 0x66, 0x77, 0x88,
				0x99, 0xaa, 0xbb, 0xcc, 0xdd, 0xee, 0xff, 0x00,
				0x11, 0x22, 0x33, 0x44, 0x55, 0x66, 0x77,
			},
			ntChallengeResponse: [24]byte{
				0x11, 0x22, 0x33, 0x44, 0x55, 0x66, 0x77, 0x88,
				0x99, 0xaa, 0xbb, 0xcc, 0xdd, 0xee, 0xff, 0x00,
				0x11, 0x22, 0x33, 0x44, 0x55, 0x66, 0x77,
			},
			expectedHashcat: "username::domain:1122334455667788:112233445566778899AABBCCDDEEFF001122334455667711:112233445566778899AABBCCDDEEFF001122334455667711",
		},
		{
			name:     "Empty Username and Domain",
			username: "",
			domain:   "",
			serverChallenge: [8]byte{
				0xaa, 0xbb, 0xcc, 0xdd, 0xee, 0xff, 0x00, 0x11,
			},
			lmChallengeResponse: [24]byte{
				0x22, 0x33, 0x44, 0x55, 0x66, 0x77, 0x88, 0x99,
				0xaa, 0xbb, 0xcc, 0xdd, 0xee, 0xff, 0x00, 0x11,
				0x22, 0x33, 0x44, 0x55, 0x66, 0x77,
			},
			ntChallengeResponse: [24]byte{
				0x22, 0x33, 0x44, 0x55, 0x66, 0x77, 0x88, 0x99,
				0xaa, 0xbb, 0xcc, 0xdd, 0xee, 0xff, 0x00, 0x11,
				0x22, 0x33, 0x44, 0x55, 0x66, 0x77,
			},
			expectedHashcat: "::::AABBCCDDEEFF0011:223344556677889999AABBCCDDEEFF001122334455667722:223344556677889999AABBCCDDEEFF001122334455667722",
		},
	}

	for _, tc := range testCases {
		t.Run(tc.name, func(t *testing.T) {
			ntlmv2Response := NewNTLMv2Response(
				tc.username,
				tc.domain,
				tc.serverChallenge,
				tc.lmChallengeResponse,
				tc.ntChallengeResponse,
			)

			hashcatString, err := ntlmv2Response.HashcatString()
			if err != nil {
				t.Fatalf("Expected no error, got %v", err)
			}

			if hashcatString != tc.expectedHashcat {
				t.Errorf("Expected hashcat string %s, got %s", tc.expectedHashcat, hashcatString)
			}
		})
	}

}
